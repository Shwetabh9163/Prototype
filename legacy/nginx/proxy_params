# Common proxy parameters — included by all API location blocks
# This file is mounted into the Nginx container

# Pass the request to the upstream backend
proxy_http_version 1.1;

# Set the Host header so the backend knows the original hostname
proxy_set_header Host $host;

# Pass the client's REAL IP address to the backend
# (critical for rate limiting — otherwise all requests look like they come from Nginx)
proxy_set_header X-Real-IP $remote_addr;

# Forward the chain of proxy IPs
proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

# Tell the backend whether the original request was HTTP or HTTPS
proxy_set_header X-Forwarded-Proto $scheme;

# Timeouts — how long Nginx waits before giving up on a backend
proxy_connect_timeout 10s;
proxy_send_timeout 30s;
proxy_read_timeout 30s;

# Handle connection upgrades (needed for WebSockets, if ever added)
proxy_set_header Upgrade $http_upgrade;
proxy_set_header Connection "upgrade";
